ADDR=:8080
DATABASE_URL=postgres://todo:todo@localhost:5432/todo?sslmode=disable
JWT_SECRET=replace-me-with-a-long-random-string

# CORS origin(s) — comma-separated. Use the frontend origin in dev.
CORS_ORIGIN=http://localhost:5173

# Where the SPA lives — used as the redirect target after Google OAuth callback.
FRONTEND_URL=http://localhost:5173

# Leave empty to disable the Google sign-in button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
